---
// About / Hero section – static content
---

<section id="about" class="py-20 scroll-mt-16">
  <div class="max-w-4xl mx-auto px-4 sm:px-6">
    <div class="flex flex-col-reverse sm:flex-row items-start gap-10">
      <!-- Text content -->
      <div class="flex-1">
        <h1 class="text-4xl font-bold text-gray-900 leading-tight tracking-tight">
          Yannick Landeck
        </h1>
        <p class="mt-2 text-lg text-blue-600 font-medium">
          Software Engineer &amp; PhD Researcher
        </p>

        <!-- Open-to-work badge -->
        <div class="mt-3 inline-flex items-center gap-2 rounded-full bg-green-50 border border-green-200 px-3 py-1">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
          </span>
          <span class="text-sm font-medium text-green-700">Open to new positions &middot; Available from July 2026</span>
        </div>

        <p class="mt-5 text-gray-600 leading-relaxed max-w-xl">
          I am a software engineer passionate about building modern, secure software solutions.
          Currently completing my PhD at TU Munich, I specialise in DevOps, containerised
          architectures, and security risk assessment. I'm also deeply interested in how LLM-based
          coding agents are reshaping software engineering, shifting focus from raw implementation
          towards problem analysis, architecture design, and verification. I enjoy working in
          interdisciplinary teams, taking ownership, and finding pragmatic solutions to complex
          challenges. Outside of work, I play snooker and enjoy hiking in the mountains.
        </p>

        <!-- Social links -->
        <div class="mt-7 flex flex-wrap items-center gap-4">
          <!-- GitHub -->
          <a
            href="https://github.com/YannickLand"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-medium text-gray-600 hover:text-blue-600 transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
              ></path>
            </svg>
            GitHub
          </a>

          <!-- LinkedIn -->
          <a
            href="https://www.linkedin.com/in/yannick-landeck-a58a2b206"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-medium text-gray-600 hover:text-blue-600 transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path>
            </svg>
            LinkedIn
          </a>

          <!-- ResearchGate -->
          <a
            href="https://www.researchgate.net/profile/Yannick-Landeck"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-medium text-gray-600 hover:text-blue-600 transition-colors"
          >
            <span
              class="inline-flex items-center justify-center w-4 h-4 text-[9px] font-bold bg-teal-500 text-white rounded"
              aria-hidden="true">RG</span
            >
            ResearchGate
          </a>

          <!-- Email (obfuscated) -->
          <a
            id="about-email"
            href="#"
            class="inline-flex items-center gap-2 text-sm font-medium text-gray-600 hover:text-blue-600 transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
            Email
          </a>
        </div>
      </div>

      <!-- Profile photo -->
      <div class="flex-shrink-0 self-center sm:self-start">
        <img
          src="/avatar.jpg"
          alt="Yannick Landeck"
          width="176"
          height="176"
          class="w-36 h-36 sm:w-44 sm:h-44 rounded-full object-cover ring-4 ring-gray-100 shadow-md"
        />
      </div>
    </div>
  </div>
</section>

<script>
  const aboutEmail = document.getElementById("about-email");
  if (aboutEmail) {
    const enc = "moc.liamg@kcednalkcinnay";
    aboutEmail.setAttribute("href", "mailto:" + enc.split("").reverse().join(""));
  }
</script>
